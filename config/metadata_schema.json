{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VIETCLAW Document Metadata Schema",
  "description": "Schema cho metadata YAML frontmatter cua cac van ban phap luat Viet Nam",
  "type": "object",
  "required": [
    "ten_van_ban",
    "so_hieu",
    "loai_van_ban",
    "co_quan_ban_hanh",
    "ngay_ban_hanh",
    "ngay_hieu_luc",
    "tinh_trang",
    "linh_vuc"
  ],
  "properties": {
    "ten_van_ban": {
      "type": "string",
      "description": "Ten day du cua van ban phap luat"
    },
    "so_hieu": {
      "type": "string",
      "description": "So hieu van ban (VD: 59/2020/QH14)",
      "pattern": "^[0-9A-Za-z/\\-]+$"
    },
    "loai_van_ban": {
      "type": "string",
      "description": "Loai van ban phap luat",
      "enum": [
        "Hien phap",
        "Bo luat",
        "Luat",
        "Phap lenh",
        "Nghi quyet",
        "Nghi dinh",
        "Quyet dinh",
        "Thong tu",
        "Thong tu lien tich",
        "Chi thi"
      ]
    },
    "co_quan_ban_hanh": {
      "type": "string",
      "description": "Co quan ban hanh van ban",
      "enum": [
        "Quoc hoi",
        "Uy ban Thuong vu Quoc hoi",
        "Chinh phu",
        "Thu tuong Chinh phu",
        "Bo Tu phap",
        "Bo Tai chinh",
        "Bo Cong an",
        "Bo Lao dong - Thuong binh va Xa hoi",
        "Bo Cong Thuong",
        "Bo Tai nguyen va Moi truong",
        "Bo Xay dung",
        "Bo Thong tin va Truyen thong",
        "Bo Ke hoach va Dau tu",
        "Bo Noi vu",
        "Bo Y te",
        "Bo Giao duc va Dao tao",
        "Bo Khoa hoc va Cong nghe",
        "Bo Nong nghiep va Phat trien nong thon",
        "Bo Giao thong van tai",
        "Bo Quoc phong",
        "Bo Ngoai giao",
        "Bo Van hoa The thao va Du lich",
        "Ngan hang Nha nuoc",
        "Toa an nhan dan toi cao",
        "Vien Kiem sat nhan dan toi cao"
      ]
    },
    "ngay_ban_hanh": {
      "type": "string",
      "format": "date",
      "description": "Ngay ban hanh (YYYY-MM-DD)"
    },
    "ngay_hieu_luc": {
      "type": "string",
      "format": "date",
      "description": "Ngay co hieu luc (YYYY-MM-DD)"
    },
    "ngay_het_hieu_luc": {
      "type": ["string", "null"],
      "format": "date",
      "description": "Ngay het hieu luc (null neu con hieu luc)"
    },
    "tinh_trang": {
      "type": "string",
      "description": "Tinh trang hieu luc",
      "enum": [
        "Con hieu luc",
        "Het hieu luc",
        "Het hieu luc mot phan",
        "Chua co hieu luc",
        "Ngung hieu luc"
      ]
    },
    "linh_vuc": {
      "type": "string",
      "description": "Linh vuc dieu chinh chinh"
    },
    "nguoi_ky": {
      "type": "string",
      "description": "Nguoi ky ban hanh van ban"
    },
    "van_ban_lien_quan": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Danh sach so hieu cac van ban lien quan"
    },
    "van_ban_thay_the": {
      "type": ["string", "null"],
      "description": "So hieu van ban bi thay the (neu co)"
    },
    "van_ban_sua_doi": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Danh sach van ban sua doi, bo sung"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Cac tags de phan loai va tim kiem"
    },
    "tom_tat": {
      "type": "string",
      "description": "Tom tat ngan gon noi dung van ban"
    }
  }
}
