# =============================================================================
# VIETLAW - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- OpenAI API (required for embeddings) ---
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Anthropic API (required for LLM queries via VietlawRAG) ---
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# --- ChromaDB (optional - defaults are in config/rag_config.yaml) ---
# CHROMA_PERSIST_DIR=./vectordb/chroma
# CHROMA_COLLECTION=vietlaw_laws

# --- Logging (optional) ---
# LOG_LEVEL=INFO
# LOG_FILE=./logs/vietlaw.log
